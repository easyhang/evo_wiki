# Copy this file to .env and replace every REPLACE_WITH_YOUR_* value.
# Never send a filled .env onward.

LLM_BINDING=openai
LLM_BINDING_HOST=https://REPLACE_WITH_YOUR_OPENAI_COMPATIBLE_ENDPOINT/v1
LLM_BINDING_API_KEY=REPLACE_WITH_YOUR_LLM_KEY
LLM_MODEL=qwen-plus

EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://REPLACE_WITH_YOUR_OPENAI_COMPATIBLE_ENDPOINT/v1
EMBEDDING_BINDING_API_KEY=REPLACE_WITH_YOUR_EMBEDDING_KEY
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_SEND_DIM=true
EMBEDDING_USE_BASE64=false

WORKSPACE=evo_wiki
ENABLE_LLM_CACHE=true
SUMMARY_LANGUAGE=Chinese
ENTITY_EXTRACTION_USE_JSON=true
MAX_PARALLEL_INSERT=2
EMBEDDING_BATCH_NUM=8
RERANK_BINDING=null

LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage
